{
  "name": "effect-indexeddb",
  "version": "1.0.0-beta.3",
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "license": "MIT",
  "description": "An Effect TS wrapper for IndexedDB.",
  "sideEffects": [],
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": "./dist/index.js",
    "./*": "./dist/*.js",
    "./internal/*": null,
    "./*/index": null
  },
  "files": [
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
		"CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist .tsbuildinfo",
    "build": "tsc -b tsconfig.build.json && pnpm babel",
    "babel": "babel dist --plugins annotate-pure-calls --out-dir dist --source-maps",
    "clean-build": "pnpm clean && pnpm build",
    "check": "tsc -b tsconfig.json",
    "lint": "eslint \"./{src,test,examples,scripts}/**/*.{ts,mjs}\"",
    "lint-fix": "pnpm lint --fix",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "changeset": "changeset",
    "bump": "changeset pre enter beta && changeset version && changeset pre exit && node scripts/changeset-cleanup.ts",
		"prepublishOnly": "pnpm check && pnpm lint && pnpm test run && pnpm clean-build"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.43"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juemrami/effect-idb"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.8",
    "@babel/core": "^7.25.2",
    "@changesets/cli": "^2.30.0",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.84.2",
    "@effect/platform-node": "4.0.0-beta.43",
    "@effect/vitest": "4.0.0-beta.43",
    "@eslint/compat": "1.1.1",
    "@eslint/eslintrc": "3.1.0",
    "@eslint/js": "9.10.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "effect": "4.0.0-beta.43",
    "eslint": "^9.10.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-codegen": "^0.28.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "fake-indexeddb": "^6.2.5",
    "tsx": "^4.17.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
