{
  "name": "effect-indexeddb",
  "version": "0.0.5",
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "license": "MIT",
  "description": "An Effect TS wrapper for IndexedDB.",
  "scripts": {
    "codegen": "build-utils prepare-v2",
    "clean-build": "rm -rf dist .tsbuildinfo build && pnpm build",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "lint": "eslint \"**/{src,test,examples,scripts,dtslint}/**/*.{ts,mjs}\"",
    "lint-fix": "pnpm lint --fix",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "peerDependencies": {
    "effect": "^3.16.10"
  },
  "exports": {
    "main": "./dist/dist/mjs/index.js",
    "module": "./dist/dist/esm/index.js",
    "types": "./dist/dist/dts/index.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juemrami/effect-idb"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "directory": "dist"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.8",
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-export-namespace-from": "^7.24.7",
    "@babel/plugin-transform-modules-commonjs": "^7.24.8",
    "@effect/build-utils": "^0.8.9",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "*",
    "@effect/vitest": "latest",
    "@eslint/compat": "1.1.1",
    "@eslint/eslintrc": "3.1.0",
    "@eslint/js": "9.10.0",
    "@types/node": "^22.5.2",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "effect": "^3.19.19",
    "eslint": "^9.10.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-codegen": "^0.28.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "fake-indexeddb": "^6.2.5",
    "tsx": "^4.17.0",
    "typescript": "^5.6.2",
    "vitest": "^3.2.4"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
